{
  "name": "@frc-framework/desktop",
  "productName": "FRC Framework",
  "version": "0.1.0",
  "description": "Structured FRC robot project workspace",
  "author": "0.2Studio",
  "homepage": "https://github.com/DDguan2010/frc-framework",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DDguan2010/frc-framework.git"
  },
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "build": "vite build --config vite.renderer.config.ts && tsc --noEmit",
    "package": "electron-forge package",
    "make": "node ../../scripts/prepare-electron-winstaller.mjs && electron-forge make",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@frc-framework/code-generator": "workspace:*",
    "@frc-framework/domain": "workspace:*",
    "@frc-framework/frc-catalog": "workspace:*",
    "@frc-framework/i18n": "workspace:*",
    "@frc-framework/java-parser": "workspace:*",
    "@frc-framework/nt-client": "workspace:*",
    "@frc-framework/presets": "workspace:*",
    "@frc-framework/project-io": "workspace:*",
    "@frc-framework/toolchain": "workspace:*",
    "@material/web": "2.5.0",
    "electron-squirrel-startup": "1.0.1",
    "lit": "3.3.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "1.8.0",
    "@types/electron-squirrel-startup": "1.0.2",
    "@types/node": "24.10.13",
    "electron": "43.1.1",
    "lodash": "4.17.21",
    "vite": "8.1.5"
  }
}
